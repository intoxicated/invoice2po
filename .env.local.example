# Copy to .env.local and fill in values
# Used by docker-compose.local.yml

DISCORD_BOT_TOKEN=your_discord_bot_token
INVOICE_CHANNEL_NAME=invoices

# Cloud Functions (Docker)
GCP_PROJECT=your_gcp_project

# LLM (LangChain) - Gemini for product identification
# GOOGLE_API_KEY=your_google_ai_api_key  # from aistudio.google.com
# LLM_PROVIDER=google  (default)
# LLM_MODEL=gemini-3-flash-preview  (default)
# To use Claude instead: LLM_PROVIDER=anthropic, ANTHROPIC_API_KEY=...

# Optional: Thrive API (leave empty to skip)
# THRIVE_API_URL=
# THRIVE_USERNAME=
# THRIVE_PASSWORD=

# Debug: Save research to output/research/, cloud function result to output/result/ (for validation)
# SAVE_RESEARCH_TO_DISK=1

# Perplexity (for cloud_function_perplexity / invoice-parse-phase1-perplexity workflow)
# PERPLEXITY_API_KEY=your_perplexity_api_key
# PERPLEXITY_MODEL=sonar  (or sonar-pro)
# PERPLEXITY_SEARCH_DOMAINS=ktown4u.com,musicplaza.com,yesasia.com  (optional)

# GCP: Run `gcloud auth application-default login` (mounts ~/.config/gcloud)
