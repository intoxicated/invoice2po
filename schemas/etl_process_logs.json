    "description": "Unique process ID"
  },
  {
    "name": "process_name",
    "type": "STRING",
    "mode": "REQUIRED",
    "description": "Name of the ETL process"
  },
  {
    "name": "start_time",
    "type": "TIMESTAMP",
    "mode": "REQUIRED",
    "description": "Process start time"
  },
  {
    "name": "end_time",
